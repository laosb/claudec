#!/usr/bin/env bash
set -euo pipefail

# ── Resolve profile directory ──────────────────────────────────────────────────
if [[ -z "${CLAUDEC_PROFILE_DIR:-}" ]]; then
    CLAUDEC_PROFILE="${CLAUDEC_PROFILE:-default}"
    CLAUDEC_PROFILE_DIR="${HOME}/.claudec/profiles/${CLAUDEC_PROFILE}"
fi

mkdir -p "${CLAUDEC_PROFILE_DIR}/home"

# ── Resolve remaining config ───────────────────────────────────────────────────
CLAUDEC_IMAGE="${CLAUDEC_IMAGE:-ghcr.io/laosb/claudec:latest}"
CLAUDEC_WORKSPACE="${CLAUDEC_WORKSPACE:-${PWD}}"
CLAUDEC_WORKSPACE_CANONICAL="$(cd "${CLAUDEC_WORKSPACE}" && pwd -P)"
CLAUDEC_WORKSPACE_HASH="$(printf '%s' "${CLAUDEC_WORKSPACE_CANONICAL}" | sha256sum | cut -d' ' -f1)"
CLAUDEC_WORKSPACE_CONTAINER="/workspace/${CLAUDEC_WORKSPACE_HASH}"

# ── Auto-update image ─────────────────────────────────────────────────────────
if [[ "${CLAUDEC_IMAGE_AUTO_UPDATE:-1}" != "0" ]]; then
    _old_id="$(container image inspect "${CLAUDEC_IMAGE}" 2>/dev/null | grep -o 'sha256:[a-f0-9]*' | tail -1 || true)"
    if container image pull --progress none "${CLAUDEC_IMAGE}" >/dev/null 2>&1; then
        _new_id="$(container image inspect "${CLAUDEC_IMAGE}" 2>/dev/null | grep -o 'sha256:[a-f0-9]*' | tail -1 || true)"
        if [[ -n "${_new_id}" && "${_old_id}" != "${_new_id}" ]]; then
            echo "claudec: loaded newer image for ${CLAUDEC_IMAGE}"
            if [[ "${CLAUDEC_IMAGE_AUTO_UPDATE_REMOVE_OLD:-1}" != "0" && -n "${_old_id}" ]]; then
                container image delete --force "${_old_id}" >/dev/null 2>&1 || true
            fi
        fi
    fi
    unset _old_id _new_id
fi

# ── Run ───────────────────────────────────────────────────────────────────────
CONTAINER_ARGS=(
    --rm -it
    -v "${CLAUDEC_PROFILE_DIR}/home:/home/claude"
    -v "${CLAUDEC_WORKSPACE}:${CLAUDEC_WORKSPACE_CONTAINER}"
    -w "${CLAUDEC_WORKSPACE_CONTAINER}"
)

if [[ "${1:-}" == "sh" ]]; then
    shift
    exec container run "${CONTAINER_ARGS[@]}" --entrypoint /bin/bash "${CLAUDEC_IMAGE}" "$@"
else
    exec container run "${CONTAINER_ARGS[@]}" "${CLAUDEC_IMAGE}" "${@+"$@"}"
fi
